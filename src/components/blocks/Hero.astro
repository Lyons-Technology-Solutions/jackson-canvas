---
import LiquidButton from '../ui/LiquidButton.astro';
---

<section class="relative h-screen bg-slate-900 overflow-hidden" id="hero-section">
  <div class="h-full w-full flex items-center justify-center overflow-hidden">
    
    <!-- Three.js Canvas Container -->
    <div id="canvas-container" class="absolute inset-0 z-0 pointer-events-none"></div>

    <!-- Background Video/Texture (Initially hidden/masked) -->
    <div class="absolute inset-0 w-full h-full z-[1] opacity-0" id="hero-bg">
      <div class="absolute inset-0 bg-gradient-to-b from-slate-900/60 via-slate-900/40 to-slate-900/80 z-10"></div>
      <img 
        src="/media/image.png" 
        alt="Pontoon Boat with Liberator Cover" 
        class="w-full h-full object-cover scale-110"
      />
    </div>

    <!-- Decorative Grid Lines -->
    <div class="absolute inset-0 z-[1] pointer-events-none opacity-20">
      <div class="absolute top-0 left-[10%] w-px h-full bg-gradient-to-b from-transparent via-white/30 to-transparent hero-line"></div>
      <div class="absolute top-0 left-[90%] w-px h-full bg-gradient-to-b from-transparent via-white/30 to-transparent hero-line"></div>
      <div class="absolute top-[20%] left-0 w-full h-px bg-gradient-to-r from-transparent via-white/20 to-transparent hero-line-h"></div>
    </div>

    <!-- Main Content Grid -->
    <div class="relative z-10 w-full h-full grid grid-cols-12 gap-4 px-8 lg:px-16">
      
      <!-- Left Column: Typography -->
      <div class="col-span-12 lg:col-span-8 flex flex-col justify-center">
        <div class="space-y-2 md:space-y-4">
          <!-- Eyebrow -->
          <div class="overflow-hidden">
            <p class="hero-eyebrow text-stone-500 text-xs md:text-sm font-semibold tracking-[0.3em] uppercase">
              Since 1945 — Jackson, Michigan
            </p>
          </div>
          
          <!-- Main Title -->
          <h1 class="hero-title leading-[0.9] font-display font-black tracking-[-0.03em] text-white select-none">
            <span class="block text-[9vw] lg:text-[6.5vw] hero-title-word">Jackson</span>
            <span class="block text-[11vw] lg:text-[8.5vw] text-stone-500 -mt-1 md:-mt-3 hero-title-word">Canvas</span>
            <span class="block text-[4.5vw] lg:text-[3vw] text-white/40 font-medium tracking-[0.1em] uppercase mt-2 hero-title-word">Company</span>
          </h1>
        </div>
        
        <!-- Tagline -->
        <div class="mt-8 md:mt-12 max-w-xl hero-tagline">
          <p class="text-lg md:text-xl text-slate-300 leading-relaxed font-light">
            Home of the Liberator Pontoon Boat Cover. 
            <span class="text-white font-medium">Covering all your canvas needs since 1945!</span>
          </p>
        </div>

        <!-- CTA Buttons -->
        <div class="mt-8 md:mt-12 flex flex-wrap gap-6 hero-cta">
          <LiquidButton href="/liberator" class="min-w-[240px]">
            Discover The Liberator
            <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </LiquidButton>
          <LiquidButton href="/canvas" variant="outline" class="min-w-[200px] text-white border-white/30 hover:bg-stone-500 hover:border-stone-500">
            Canvas Services
          </LiquidButton>
        </div>
      </div>

      <!-- Right Column: Stats/Info -->
      <div class="hidden lg:flex col-span-4 flex-col justify-center items-end pr-8">
        <div class="space-y-12 hero-stats">
          <div class="text-right">
            <span class="block text-6xl xl:text-7xl font-display font-black text-white/10 leading-none">60+</span>
            <span class="text-xs uppercase tracking-[0.2em] text-slate-400 mt-2 block">Years of Excellence</span>
          </div>
          <div class="text-right">
            <span class="block text-6xl xl:text-7xl font-display font-black text-white/10 leading-none">29K</span>
            <span class="text-xs uppercase tracking-[0.2em] text-slate-400 mt-2 block">Sq. Ft. Facility</span>
          </div>
          <div class="text-right">
            <span class="block text-6xl xl:text-7xl font-display font-black text-stone-500/20 leading-none">#1</span>
            <span class="text-xs uppercase tracking-[0.2em] text-slate-400 mt-2 block">Semi-Auto Cover</span>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 hero-scroll">
      <span class="text-white/40 text-[10px] uppercase tracking-[0.3em]">Scroll</span>
      <div class="w-px h-12 bg-gradient-to-b from-white/40 to-transparent relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-4 bg-stone-500 animate-scroll-line"></div>
      </div>
    </div>

    <!-- Corner Accent -->
    <div class="absolute bottom-0 right-0 w-32 h-32 border-r-2 border-b-2 border-stone-500/20 hero-corner animate-fade-up" style="--delay: 1.1s"></div>
  </div>
</section>

<style>
  @keyframes scroll-line {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(400%); }
  }
  .animate-scroll-line {
    animation: scroll-line 1.5s ease-in-out infinite;
  }
  
  /* CSS-based entrance animations as fallback/primary */
  @keyframes hero-fade-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  @keyframes hero-fade-right {
    from {
      opacity: 0;
      transform: translateX(30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
  
  @keyframes hero-scale-y {
    from { transform: scaleY(0); }
    to { transform: scaleY(1); }
  }
  
  @keyframes hero-scale-x {
    from { transform: scaleX(0); }
    to { transform: scaleX(1); }
  }
  
  .hero-line {
    transform-origin: top;
    animation: hero-scale-y 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: 0.2s;
    transform: scaleY(0);
  }
  
  .hero-line-h {
    transform-origin: left;
    animation: hero-scale-x 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: 0.4s;
    transform: scaleX(0);
  }
  
  .hero-eyebrow {
    animation: hero-fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: 0.3s;
    opacity: 0;
  }
  
  .hero-title-word {
    animation: hero-fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }
  
  .hero-title-word:nth-child(1) { animation-delay: 0.4s; }
  .hero-title-word:nth-child(2) { animation-delay: 0.5s; }
  .hero-title-word:nth-child(3) { animation-delay: 0.6s; }
  
  .hero-tagline {
    animation: hero-fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: 0.7s;
    opacity: 0;
  }
  
  .hero-cta {
    animation: hero-fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: 0.8s;
    opacity: 0;
  }
  
  .hero-stats {
    animation: hero-fade-right 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: 0.9s;
    opacity: 0;
  }
  
  .hero-scroll {
    animation: hero-fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: 1s;
    opacity: 0;
  }
  
  .animate-fade-up {
    animation: hero-fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--delay, 0s);
    opacity: 0;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  
  gsap.registerPlugin(ScrollTrigger);

  // Scroll-driven parallax for hero background
  ScrollTrigger.create({
    trigger: "#hero-section",
    start: "top top",
    end: "bottom top",
    scrub: true,
    onUpdate: (self) => {
      const heroBg = document.getElementById("hero-bg");
      if (heroBg) {
        heroBg.style.opacity = String(self.progress);
      }
    }
  });

  // Title scale on scroll
  ScrollTrigger.create({
    trigger: "#hero-section",
    start: "top top",
    end: "50% top",
    scrub: true,
    onUpdate: (self) => {
      const heroTitle = document.querySelector(".hero-title") as HTMLElement;
      if (heroTitle) {
        heroTitle.style.transform = `scale(${1 + (self.progress * 0.5)})`;
        heroTitle.style.opacity = String(1 - self.progress);
      }
    }
  });
</script>
