---
interface Props {
  class?: string;
  id?: string;
  theme?: 'light' | 'dark';
}

const { class: className, id, theme = 'light' } = Astro.props;

const themeStyles = {
  light: "bg-white text-slate-900",
  dark: "bg-slate-900 text-white"
};
---

<section id={id} class:list={["py-24 md:py-32 px-6 md:px-12 max-w-[1920px] mx-auto", themeStyles[theme], className]}>
  <slot />
</section>
