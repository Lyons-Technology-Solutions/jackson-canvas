---
const currentYear = new Date().getFullYear();
---

<footer class="bg-slate-950 text-slate-400 py-24 px-6 md:px-12 border-t border-slate-900">
  <div class="max-w-[1920px] mx-auto grid grid-cols-1 md:grid-cols-4 gap-12 md:gap-24">
    
    <!-- Brand -->
    <div class="space-y-6">
      <a href="/" class="block group">
        <img src="/logo.png" alt="Jackson Canvas Co." class="h-12 w-auto object-contain brightness-0 invert opacity-80 group-hover:opacity-100 transition-opacity" />
      </a>
      <p class="text-sm leading-relaxed max-w-xs text-slate-400">
        Engineering protection systems and custom fabrication solutions since 1945. Home of The Liberator.
      </p>
      <div class="pt-4">
        <p class="text-xs uppercase tracking-widest text-slate-600 mb-2">Established</p>
        <p class="text-white font-serif italic text-lg">Jackson, Michigan</p>
      </div>
    </div>

    <!-- Navigation -->
    <div>
      <h3 class="text-xs font-bold uppercase tracking-widest text-white mb-6">Explore</h3>
      <ul class="space-y-4 text-sm font-medium">
        <li><a href="/liberator" class="hover:text-stone-500 transition-colors">Liberator</a></li>
        <li><a href="/liberator-gallery" class="hover:text-stone-500 transition-colors">Gallery</a></li>
        <li><a href="/canvas" class="hover:text-stone-500 transition-colors">Canvas Services</a></li>
        <li><a href="/faq" class="hover:text-stone-500 transition-colors">FAQ</a></li>
        <li><a href="/contact" class="hover:text-stone-500 transition-colors">Contact Us</a></li>
      </ul>
    </div>

    <!-- Contact -->
    <div>
      <h3 class="text-xs font-bold uppercase tracking-widest text-white mb-6">Contact</h3>
      <ul class="space-y-4 text-sm">
        <li>
          <span class="block text-slate-600 text-xs mb-1">Call Us</span>
          <a href="tel:517-787-1330" class="text-white hover:text-stone-500 transition-colors">(517) 787-1330</a>
        </li>
        <li>
          <span class="block text-slate-600 text-xs mb-1">Visit (By Appointment)</span>
          <address class="not-italic text-white">
            2100 Brooklyn Road<br>
            Jackson, MI 49203
          </address>
        </li>
        <li>
          <span class="block text-slate-600 text-xs mb-1">Hours</span>
          <p class="text-white">Monday - Friday</p>
          <p class="text-white">By appointment only</p>
        </li>
      </ul>
    </div>

    <!-- Social / Legal -->
    <div>
      <h3 class="text-xs font-bold uppercase tracking-widest text-white mb-6">Legal</h3>
      <ul class="space-y-4 text-sm">
        <li><a href="/privacy" class="hover:text-white transition-colors">Privacy Policy</a></li>
        <li><a href="/terms" class="hover:text-white transition-colors">Terms of Service</a></li>
      </ul>
      <p class="mt-8 text-xs text-slate-600">
        &copy; {currentYear} Jackson Canvas Company<br>
        All rights reserved.
      </p>
    </div>

  </div>
</footer>
