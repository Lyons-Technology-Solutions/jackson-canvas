---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/layout/Navigation.astro';
import Footer from '../components/layout/Footer.astro';
import Section from '../components/ui/Section.astro';
import LiquidButton from '../components/ui/LiquidButton.astro';
import Accordion from '../components/ui/Accordion.astro';

const features = [
  {
    title: "Deploys in Seconds",
    description: "No more snapping buttons. Cover or uncover your boat in under 60 seconds with a simple key turn."
  },
  {
    title: "Solar Powered",
    description: "Independent 12V DC system charged by a solar panel. No need to plug into your dock or boat battery."
  },
  {
    title: "Superior Protection",
    description: "Keeps your interior pristine. Protects against UV rays, rain, and debris better than traditional snaps."
  },
  {
    title: "Wireless Operation",
    description: "Key fob remote control allows you to operate the cover from the dock or as you approach."
  }
];

const faqs = [
  {
    question: "Will The Liberator work on my boat?",
    answer: "Yes, so far we have been able to fit 100% of the boats assembled to date."
  },
  {
    question: "What powers The Liberator?",
    answer: "It uses your standard 12 volt battery."
  },
  {
    question: "Is it all weather?",
    answer: "The Liberator is manufactured of marine grade everything, utilizing aluminum, plastic and stainless steel."
  },
  {
    question: "What color choices are available?",
    answer: "We are using only Weathermax 80 for the top cover material and the colors they offer."
  },
  {
    question: "Can I trailer with The Liberator top?",
    answer: "Yes you can, at less than highway speeds, however the sides and rear corners need to be tied down with the provided straps."
  },
  {
    question: "How fast can I go with The Liberator top extended?",
    answer: "The Liberator has been tested to 60 MPH."
  },
  {
    question: "What about winter storage?",
    answer: "The Liberator is not designed to handle heavy wet snow loads. The cover canvas must be removed before shrink wrap is applied."
  },
  {
    question: "What is the warranty?",
    answer: "3 years normal and customary."
  },
  {
    question: "How long will I be without my boat?",
    answer: "It takes only 3-4 days to add The Liberator. We will need your boat in Jackson MI to do the work."
  }
];

const specs = [
  { label: "Material", value: "Weathermax 80 Cover Material" },
  { label: "Frame", value: "Aluminum, Plastic & Stainless Steel" },
  { label: "Power", value: "Standard 12V Battery" },
  { label: "Warranty", value: "3 Years Normal & Customary" },
  { label: "Installation", value: "3-4 Days in Jackson, MI" },
  { label: "Max Speed", value: "Tested to 60 MPH" }
];
---

<Layout title="The Liberator | Jackson Canvas Company">
  <Navigation />
  
  <main>
    <!-- Product Hero -->
    <section class="relative min-h-screen bg-slate-900 flex items-center overflow-hidden">
      <div class="absolute inset-0 z-0">
        <img 
          src="https://jacksoncanvas.com/wp-content/uploads/The_Liberator_By_JCC-transp-scaled.jpg" 
          alt="The Liberator Pontoon Cover" 
          class="w-full h-full object-cover opacity-20"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-slate-900 via-slate-900/90 to-slate-900/70"></div>
      </div>
      
      <div class="relative z-10 px-6 md:px-12 max-w-[1920px] mx-auto w-full py-32">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <div class="max-w-2xl">
            <span class="text-stone-500 font-bold tracking-widest uppercase mb-4 block">The World's Only Semi-Automatic Cover</span>
            <h1 class="text-5xl md:text-7xl font-display font-bold text-white mb-8 leading-tight reveal-text">
              Liberate Your <br>
              <span class="text-stone-500 font-serif italic">Summer.</span>
            </h1>
            <p class="text-xl text-slate-300 mb-10 leading-relaxed reveal-text">
              Uncover your pontoon boat in less than 2 minutes. Waterproof remote control key fob for raising and lowering the cover. Patent Pending.
            </p>
            <div class="flex flex-wrap gap-4">
              <LiquidButton href="#contact">Request Quote</LiquidButton>
              <LiquidButton href="/liberator-gallery" variant="outline" class="text-white border-white hover:bg-stone-500 hover:border-stone-500">Image Gallery</LiquidButton>
              <LiquidButton href="/faq" variant="outline" class="text-white border-white hover:bg-stone-500 hover:border-stone-500">FAQs</LiquidButton>
            </div>
          </div>

          <div class="relative hero-video-container">
            <div class="aspect-video rounded-xl overflow-hidden shadow-2xl border border-white/10">
              <video
                src="https://dreamgo.b-cdn.net/LTS/Liberator_FullScreen.mp4"
                autoplay
                muted
                loop
                playsinline
                class="w-full h-full object-cover"
              ></video>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Key Features Grid -->
    <Section class="bg-white">
      <div class="text-center max-w-3xl mx-auto mb-24 reveal-text">
        <h2 class="text-3xl md:text-4xl font-display font-bold mb-6">Why Choose The Liberator?</h2>
        <p class="text-slate-600 text-lg">Traditional covers are a hassle. Snaps shrink, break, and hurt your fingers. The Liberator solves the pain of pontoon ownership.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
        {features.map((feature, index) => (
          <div class="group border-t border-slate-200 pt-8 hover:border-stone-600 transition-colors duration-500">
            <span class="text-6xl font-display font-black text-slate-100 group-hover:text-stone-600/20 transition-colors duration-500 mb-6 block">
              {(index + 1).toString().padStart(2, '0')}
            </span>
            <h3 class="text-2xl font-display font-bold mb-4">{feature.title}</h3>
            <p class="text-slate-600 leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </Section>

    <!-- Video / Demo Section -->
    <Section id="video" theme="dark" class="relative">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-3xl md:text-5xl font-display font-bold mb-8">See it in action.</h2>
          <p class="text-slate-300 text-lg mb-8 leading-relaxed">
            Watch how effortlessly the Liberator deploys. Our patented mechanism ensures a tight, secure fit every time, without the struggle of manual snaps.
          </p>
          
          <ul class="space-y-6 mb-8">
            {["Fits most standard pontoons", "Custom color options", "Professional installation included"].map(item => (
              <li class="flex items-center gap-4 text-slate-300">
                <span class="w-2 h-2 rounded-full bg-stone-600"></span>
                <span class="text-lg font-medium text-white">{item}</span>
              </li>
            ))}
          </ul>
        </div>
        
        <div class="relative aspect-video bg-slate-800 rounded-xl overflow-hidden shadow-2xl border border-slate-700 group cursor-pointer">
          <!-- Placeholder for Video Embed -->
          <img 
             src="https://jacksoncanvas.com/wp-content/uploads/liberator-front-page-1.jpg" 
             alt="Liberator Demo" 
             class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity duration-300" 
          />
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-20 h-20 rounded-full bg-stone-600 flex items-center justify-center pl-1 group-hover:scale-110 transition-transform duration-300 shadow-xl">
              <div class="w-0 h-0 border-t-[10px] border-t-transparent border-l-[18px] border-l-white border-b-[10px] border-b-transparent ml-1"></div>
            </div>
          </div>
        </div>
      </div>
    </Section>

    <!-- Technical Specs -->
    <Section class="bg-slate-50">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div class="bg-white p-12 rounded-2xl shadow-sm reveal-image">
          <h3 class="text-2xl font-display font-bold mb-8">Technical Specifications</h3>
          <div class="space-y-6">
            {specs.map(spec => (
              <div class="flex justify-between items-center border-b border-slate-100 pb-4 last:border-0 last:pb-0">
                <span class="font-medium text-slate-500">{spec.label}</span>
                <span class="font-bold text-slate-900 text-right">{spec.value}</span>
              </div>
            ))}
          </div>
        </div>
        
        <div class="flex flex-col justify-center reveal-text">
          <h3 class="text-2xl font-display font-bold mb-6">Built for the Elements</h3>
          <p class="text-slate-600 mb-8 leading-relaxed">
            Every Liberator is manufactured right here in Jackson, Michigan using the highest quality materials available. We don't cut corners because we know what the Great Lakes weather can do.
          </p>
          <div class="grid grid-cols-2 gap-6">
             <div class="bg-white p-6 rounded-lg text-center border border-slate-100 transition-transform duration-500 hover:-translate-y-1">
               <span class="block text-3xl font-bold text-stone-600 mb-2">60+</span>
               <span class="text-xs uppercase tracking-widest text-slate-500">Years Experience</span>
             </div>
             <div class="bg-white p-6 rounded-lg text-center border border-slate-100 transition-transform duration-500 hover:-translate-y-1">
               <span class="block text-3xl font-bold text-stone-600 mb-2">100%</span>
               <span class="text-xs uppercase tracking-widest text-slate-500">Made in USA</span>
             </div>
          </div>
        </div>
      </div>
    </Section>

    <!-- FAQ -->
    <Section>
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl font-display font-bold mb-12 text-center">Frequently Asked Questions</h2>
        <Accordion items={faqs} />
      </div>
    </Section>

    <!-- CTA -->
    <Section id="contact" theme="dark" class="text-center">
       <h2 class="text-4xl md:text-6xl font-display font-bold mb-6">Get Your Quote</h2>
       <p class="text-slate-300 text-lg mb-10 max-w-2xl mx-auto">
         Ready to upgrade your boating experience? Contact us today for pricing and availability for your specific pontoon model.
       </p>
       <LiquidButton href="/contact">Contact Sales Team</LiquidButton>
    </Section>

  </main>

  <Footer />
</Layout>

<script>
  import { animate, inView, stagger } from "motion";

  // Reveal animations
  inView(".reveal-text", (info) => {
    animate(info.target, { opacity: [0, 1], y: [30, 0] }, { duration: 0.8, easing: [0.16, 1, 0.3, 1] });
  });

  inView(".reveal-image", (info) => {
    animate(info.target, { opacity: [0, 1], scale: [0.95, 1] }, { duration: 1, easing: [0.16, 1, 0.3, 1] });
  });

  inView(".hero-video-container", (info) => {
    animate(info.target, { opacity: [0, 1], x: [60, 0] }, { duration: 1, easing: [0.16, 1, 0.3, 1], delay: 0.3 });
  });

  // Staggered Feature Cards
  inView(".group.border-t", (info) => {
    const cards = document.querySelectorAll(".group.border-t");
    animate(cards, { opacity: [0, 1], y: [50, 0] }, { 
      delay: stagger(0.1),
      duration: 0.8, 
      easing: [0.16, 1, 0.3, 1] 
    });
  });
</script>
