---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/layout/Navigation.astro';
import Footer from '../components/layout/Footer.astro';
import Hero from '../components/blocks/Hero.astro';
import HorizontalCarousel from '../components/blocks/HorizontalCarousel.astro';
import Section from '../components/ui/Section.astro';
import LiquidButton from '../components/ui/LiquidButton.astro';
import { ArrowRight } from 'lucide-react';
---

<Layout title="Jackson Canvas Company - Home of the Liberator">
  <Navigation />
  
  <main>
    <Hero />
    
    <!-- About Us Section -->
    <Section class="py-32 md:py-40">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
        <div class="md:col-span-7">
          <span class="text-stone-600 font-bold tracking-widest uppercase mb-4 block">About Us</span>
          <h2 class="text-3xl md:text-5xl font-display font-medium leading-tight mb-8">
            We've Got You <span class="font-serif italic text-stone-600">Covered</span>
          </h2>
          <div class="space-y-6 text-lg text-slate-600 max-w-2xl leading-relaxed">
            <p class="reveal-text">
              Jackson Canvas operates out of a 29,000 square foot facility in Jackson, Michigan. We have been serving customers for more than 60 years.
            </p>
            <p class="reveal-text">
              We provide both design and manufacture of quality canvas goods along with production metal fabrications. We are the home of <strong>The Liberator</strong>—the semi-automatic pontoon boat cover.
            </p>
          </div>
          <div class="mt-8">
            <LiquidButton href="/about" variant="text">
              Our History <ArrowRight className="w-4 h-4" />
            </LiquidButton>
          </div>
        </div>
        <div class="md:col-span-5 relative group">
          <div class="aspect-square bg-slate-100 rounded-lg overflow-hidden relative shadow-2xl reveal-image">
             <img 
              src="/media/image copy.png" 
              alt="Pontoon Boat with Cover" 
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
            />
            <div class="absolute inset-0 bg-slate-900/10 group-hover:bg-slate-900/0 transition-colors duration-500"></div>
          </div>
        </div>
      </div>
    </Section>

    <!-- Services Grid -->
    <Section class="bg-slate-50 py-32 md:py-40 overflow-hidden">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 services-grid">
        {[
          {
            id: "01",
            title: "Marine Solutions",
            description: "Custom covers, upholstery, and the flagship Liberator system designed for the open water."
          },
          {
            id: "02",
            title: "Industrial Canvas",
            description: "Heavy-duty protection for machinery, equipment, and architectural applications."
          },
          {
            id: "03",
            title: "Metal Fabrication",
            description: "In-house welding and frame construction ensuring structural integrity for every project."
          }
        ].map((service, index) => (
          <div class="service-card group border-t border-slate-200 pt-8 hover:border-stone-600 transition-colors duration-500 relative">
            <div class="overflow-hidden mb-6">
              <span class="service-number font-display font-bold text-4xl text-slate-200 group-hover:text-stone-600 transition-colors duration-500 block">
                {service.id}
              </span>
            </div>
            <h3 class="text-2xl font-display font-bold mb-4 translate-y-0 group-hover:-translate-y-1 transition-transform duration-500">{service.title}</h3>
            <p class="text-slate-600 leading-relaxed max-w-sm group-hover:text-slate-900 transition-colors duration-500">{service.description}</p>
            
            <!-- Animated Background Glow -->
            <div class="absolute -inset-4 bg-stone-500/0 group-hover:bg-stone-500/5 rounded-xl -z-10 transition-colors duration-500"></div>
          </div>
        ))}
      </div>
    </Section>

    <HorizontalCarousel />
    
    <!-- Liberator Teaser -->
    <Section theme="dark" class="relative overflow-hidden min-h-[80vh] flex items-center">
      <!-- Background Image with Overlay -->
      <div class="absolute inset-0 z-0">
        <video
          src="https://dreamgo.b-cdn.net/LTS/Liberator_FullScreen.mp4"
          autoplay
          muted
          loop
          playsinline
          class="w-full h-full object-cover opacity-60 scale-105"
          id="liberator-video"
        ></video>
        <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/80 to-slate-900/60"></div>
      </div>

      <div class="relative z-10 text-center max-w-4xl mx-auto">
        <span class="text-stone-500 font-bold tracking-widest uppercase mb-4 block">The Flagship Product</span>
        <h2 class="text-5xl md:text-7xl font-display font-bold mb-8 text-white">
          Meet The <span class="text-stone-500 font-serif italic">Liberator</span>
        </h2>
        <p class="text-xl text-slate-300 mb-12 leading-relaxed max-w-2xl mx-auto">
          Uncover your pontoon boat in less than 2 minutes. Waterproof remote control key fob for raising and lowering the cover. Patent Pending.
        </p>
        <div class="flex flex-col md:flex-row gap-4 justify-center">
          <LiquidButton href="/liberator">Discover The Liberator</LiquidButton>
          <LiquidButton href="/contact" variant="outline" class="text-white border-white hover:bg-stone-500 hover:border-stone-500">
            Request Quote
          </LiquidButton>
        </div>
      </div>
    </Section>
  </main>

  <Footer />
</Layout>

<script>
  import { animate, scroll, inView, stagger } from "motion";
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // Initial Entrance
  inView(".reveal-text", (info) => {
    animate(info.target, { opacity: [0, 1], y: [30, 0] }, { duration: 0.8, easing: [0.16, 1, 0.3, 1] });
  });

  inView(".reveal-image", (info) => {
    animate(info.target, { opacity: [0, 1], scale: [0.95, 1] }, { duration: 1, easing: [0.16, 1, 0.3, 1] });
  });

  // Staggered Service Cards with GSAP
    gsap.from(".service-card", {
      y: 60,
      opacity: 0,
      stagger: 0.15,
      duration: 1.2,
      ease: "power4.out",
      scrollTrigger: {
        trigger: ".services-grid",
        start: "top 80%",
      }
    });

    // Animate service numbers specifically
    gsap.from(".service-number", {
      y: 40,
      opacity: 0,
      stagger: 0.15,
      duration: 1,
      delay: 0.2,
      ease: "power3.out",
      scrollTrigger: {
        trigger: ".services-grid",
        start: "top 80%",
      }
    });

  // Liberator Section Parallax
  const liberatorVideo = document.getElementById('liberator-video');
  if (liberatorVideo) {
    scroll(
      animate(liberatorVideo, { y: ["-10%", "10%"] }),
      { target: liberatorVideo.parentElement! }
    );
  }

</script>
